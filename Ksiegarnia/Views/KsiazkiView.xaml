<UserControl x:Class="Ksiegarnia.Views.KsiazkiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Lista Książek" FontSize="22" Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Booksfull}"
          AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"    Binding="{Binding Id}" Width="30"/>
                <DataGridTextColumn Header="Tytuł" Binding="{Binding Tytul}"      Width="*"/>
                <DataGridTextColumn Header="Autor" Binding="{Binding Autor}"      Width="*"/>
                <DataGridTextColumn Header="Cena"  Binding="{Binding Cena, StringFormat=F2}"       Width="40"/>
                <DataGridTextColumn Header="Magazyn (szt.)"  Binding="{Binding Stan}"       Width="100"/>
                <DataGridTextColumn Header="Wypozyczone (szt.)"  Binding="{Binding Wypozyczone}"       Width="100"/>
                <DataGridTemplateColumn Header="Akcje" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                <Button Content="Edytuj" Tag="{Binding}" Click="btnEdit_Click"
                                Margin="2"/>

                                <Button Content="Usuń" Tag="{Binding}" Click="btnDelete_Click"
                                Margin="2"/>

                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Border Background="#34495E" Grid.Row="2" Height="50" Width="210">
            <Button Content="DODAJ"
Click="btnAdd_Click"
Margin="5" Height="40" Width="200" HorizontalAlignment="Center" Background="LightGreen"/>
        </Border>
    </Grid>
</UserControl>