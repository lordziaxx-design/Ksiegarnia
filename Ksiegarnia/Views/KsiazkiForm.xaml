<Window x:Class="Ksiegarnia.KsiazkaForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Ksiegarnia.ViewModels"
        xmlns:views="clr-namespace:Ksiegarnia.Views"
        Title="Księgarnia" Height="350" Width="300">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#2C3E50" Height="60">
            <TextBlock Text="Ksiązki"
               Foreground="White" FontSize="20"
               VerticalAlignment="Center" Margin="20,0" HorizontalAlignment="Center"/>
           
        </Grid>
        <Grid Grid.Row="1" Height="30" Margin="5">
            <TextBlock Text="Nazwa" FontSize="20" Margin="10,0"/>
            <TextBox Width="150" Height="30" HorizontalAlignment="Right" Name="nazwa"/>
        </Grid>
        <Grid Grid.Row="2" Height="30" Margin="5">
            <TextBlock Text="Autor" FontSize="20" Margin="10,0"/>
            <TextBox Width="150" Height="30" HorizontalAlignment="Right" Name="autor"/>
        </Grid>
        <Grid Grid.Row="3" Height="30" Margin="5">
            <TextBlock Text="Cena" FontSize="20" Margin="10,0"/>
            <TextBox Width="150" Height="30" HorizontalAlignment="Right" Name="cena"/>
        </Grid>
        <Grid Grid.Row="4" Height="30" Margin="5">
            <TextBlock Text="Szt. Magazyn" FontSize="20" Margin="10,0"/>
            <TextBox Width="150" Height="30" HorizontalAlignment="Right" Name="mag"/>
        </Grid>
        <Grid Grid.Row="5" Height="40" Margin="5">
            <Border Background="#34495E" Grid.Row="2" Height="35" Width="204">
                <Button Content="ZATWIERDŹ"
        Tag="{Binding}" Click="btnSave_Click"
Margin="2" Height="33" Width="200" HorizontalAlignment="Center" Background="LightGreen"/>
            </Border>
        </Grid>
        <!-- TOP BAR -->
        
    </Grid>
</Window>