<UserControl x:Class="Ksiegarnia.Views.KlienciView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Lista Klientów" FontSize="22" Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Clients}"
          AutoGenerateColumns="False" IsReadOnly="True" Margin="10,10,10,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"             Binding="{Binding ID}"       Width="50"/>
                <DataGridTextColumn Header="Imię"           Binding="{Binding Imie}"     Width="*"/>
                <DataGridTextColumn Header="Nazwisko"       Binding="{Binding Nazwisko}" Width="*"/>
                <DataGridTextColumn Header="Email"          Binding="{Binding Email}"    Width="*"/>
                <DataGridTextColumn Header="Telefon"        Binding="{Binding Telefon}"  Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>