<UserControl x:Class="Ksiegarnia.Views.KlienciView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Lista Klientów" FontSize="22" Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Clients}"
          AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"             Binding="{Binding ID}"       Width="50"/>
                <DataGridTextColumn Header="Imię"           Binding="{Binding Imie}"     Width="*"/>
                <DataGridTextColumn Header="Nazwisko"       Binding="{Binding Nazwisko}" Width="*"/>
                <DataGridTextColumn Header="Email"          Binding="{Binding Email}"    Width="*"/>
                <DataGridTextColumn Header="Telefon"        Binding="{Binding Telefon}"  Width="*"/>
                <DataGridTemplateColumn Header="Akcje" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                <Button Content="Edytuj" Tag="{Binding}" Click="btnEdit_Click"
                                Margin="2"/>

                                <Button Content="Usuń" Tag="{Binding}" Click="btnDelete_Click"
                                Margin="2"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Background="#34495E" Grid.Row="2" Height="50" Width="210">
            <Button Content="DODAJ"
Click="btnAdd_Click"
Margin="5" Height="40" Width="200" HorizontalAlignment="Center" Background="LightGreen"/>
        </Border>
    </Grid>

</UserControl>